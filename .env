# 🔥 PROXY CONFIGURATION (REQUIRED if IP blocked)
# ใช้ Proxy ถ้าเชื่อมต่อ IQ Option ไม่ได้
# รูปแบบ: http://host:port หรือ http://user:pass@host:port
# ตัวอย่าง:
#   HTTPS_PROXY=http://proxy.example.com:8080
#   HTTPS_PROXY=http://username:password@proxy.example.com:8080
#
# หา Proxy ฟรีได้ที่:
# - https://free-proxy-list.net/
# - https://www.proxy-list.download/
#
# หรือใช้ VPN แทน

# HTTPS_PROXY=http://your-proxy-host:port
# HTTP_PROXY=http://your-proxy-host:port

# VPS / Remote Server Configuration (For when local network is blocked)
# VPS_HOST=your-vps-ip          # VPS IP address or hostname
# VPS_USER=root                 # SSH username (default: root)
# VPS_PASS=your-password        # SSH password
# VPS_PORT=22                   # SSH port (default: 22)
# VPS_PATH=/root/iq-option-bot  # Remote path for deployment

